---
// Layered architecture diagram: request -> control plane -> NNG mesh -> workers -> nspawn -> dormancy.
---
<div class="diagram">
  <svg viewBox="0 0 640 420" role="img" aria-label="Machineuse architecture: a client requests a browser from the control plane, which schedules it over a brokerless NNG mesh onto a worker node running the browser in a systemd-nspawn container, with idle instances snapshotted to dormancy">
    <defs>
      <linearGradient id="ad-g" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#6ee7b7" />
        <stop offset="1" stop-color="#38bdf8" />
      </linearGradient>
      <marker id="ad-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto">
        <path d="M0 0 L10 5 L0 10 z" fill="#38bdf8" />
      </marker>
    </defs>

    <!-- client -->
    <rect x="250" y="16" width="140" height="42" rx="10" fill="#0f141c" stroke="#1e2836" stroke-width="1.4" />
    <text x="320" y="35" text-anchor="middle" fill="#e6edf3" font-family="ui-monospace, monospace" font-size="12" font-weight="700">Client / API / MCP</text>
    <text x="320" y="49" text-anchor="middle" fill="#9aa7b6" font-family="ui-monospace, monospace" font-size="8.5">"give me a browser"</text>

    <path d="M320 58 L320 84" stroke="#38bdf8" stroke-width="1.6" marker-end="url(#ad-arrow)" />

    <!-- control plane -->
    <rect x="180" y="86" width="280" height="52" rx="12" fill="#131a24" stroke="url(#ad-g)" stroke-width="1.8" />
    <text x="320" y="108" text-anchor="middle" fill="#e6edf3" font-family="ui-monospace, monospace" font-size="13" font-weight="700">Control plane</text>
    <text x="320" y="124" text-anchor="middle" fill="#9aa7b6" font-family="ui-monospace, monospace" font-size="9">load-aware scheduling · metrics · auto-healing</text>

    <!-- NNG mesh band -->
    <rect x="60" y="158" width="520" height="26" rx="8" fill="#0f141c" stroke="#1e2836" stroke-width="1.2" stroke-dasharray="5 5" />
    <text x="320" y="175" text-anchor="middle" fill="#6ee7b7" font-family="ui-monospace, monospace" font-size="10" font-weight="600">brokerless NNG mesh — no central broker</text>

    <path d="M320 138 L320 158" stroke="#38bdf8" stroke-width="1.6" marker-end="url(#ad-arrow)" />

    <!-- workers -->
    {[130, 320, 510].map((cx, i) => (
      <g>
        <path d={`M${cx} 184 L${cx} 210`} stroke="#38bdf8" stroke-width="1.4" marker-end="url(#ad-arrow)" opacity="0.8" />
        <rect x={cx - 88} y="212" width="176" height="120" rx="12" fill="#0f141c" stroke="#1e2836" stroke-width="1.4" />
        <text x={cx} y="232" text-anchor="middle" fill="#e6edf3" font-family="ui-monospace, monospace" font-size="11" font-weight="700">worker-{i + 1}</text>
        <text x={cx} y="246" text-anchor="middle" fill="#9aa7b6" font-family="ui-monospace, monospace" font-size="8">agent · reports live load</text>
        {/* nspawn containers */}
        {[0, 1].map((j) => (
          <g>
            <rect x={cx - 78 + j * 82} y="256" width="72" height="60" rx="8" fill="#131a24" stroke="url(#ad-g)" stroke-width="1.2" />
            <text x={cx - 42 + j * 82} y="278" text-anchor="middle" fill="#e6edf3" font-family="ui-monospace, monospace" font-size="8" font-weight="600">nspawn</text>
            <text x={cx - 42 + j * 82} y="290" text-anchor="middle" fill="#9aa7b6" font-family="ui-monospace, monospace" font-size="7">container</text>
            <circle cx={cx - 42 + j * 82} cy="304" r="6" fill="none" stroke="#6ee7b7" stroke-width="1.2" />
            <path d={`M${cx - 45 + j * 82} 304 h6 M${cx - 42 + j * 82} 301 v6`} stroke="#6ee7b7" stroke-width="1" opacity="0.6" />
          </g>
        ))}
      </g>
    ))}

    <!-- dormancy -->
    <rect x="210" y="360" width="220" height="44" rx="10" fill="#0f141c" stroke="#1e2836" stroke-width="1.2" stroke-dasharray="4 4" />
    <text x="320" y="380" text-anchor="middle" fill="#e6edf3" font-family="ui-monospace, monospace" font-size="10" font-weight="600">snapshot dormancy</text>
    <text x="320" y="394" text-anchor="middle" fill="#9aa7b6" font-family="ui-monospace, monospace" font-size="8">idle → snapshot · revive on demand</text>
    <path d="M320 332 L320 360" stroke="#6ee7b7" stroke-width="1.4" stroke-dasharray="4 3" marker-end="url(#ad-arrow)" opacity="0.7" />
  </svg>
  <p class="cap">Request → schedule → NNG mesh → worker → nspawn container → dormancy lifecycle</p>
</div>
