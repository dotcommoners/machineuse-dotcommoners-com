---
// Animated control-plane -> workers cluster diagram (SVG).
// Used in the homepage hero and referenced on the architecture page.
const { caption = 'Control plane scheduling browsers across a worker mesh' } = Astro.props;
---
<div class="diagram">
  <svg viewBox="0 0 460 300" role="img" aria-label="Machineuse cluster: a control plane schedules isolated browsers onto worker nodes over a brokerless NNG mesh">
    <defs>
      <linearGradient id="cd-g" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#6ee7b7" />
        <stop offset="1" stop-color="#38bdf8" />
      </linearGradient>
      <filter id="cd-glow" x="-40%" y="-40%" width="180%" height="180%">
        <feGaussianBlur stdDeviation="3.5" result="b" />
        <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
      </filter>
    </defs>

    <!-- mesh links (control plane -> workers) -->
    <g stroke="url(#cd-g)" stroke-width="1.6" fill="none" opacity="0.75">
      <path class="mesh-line" d="M230 78 L110 168" />
      <path class="mesh-line" d="M230 78 L230 168" />
      <path class="mesh-line" d="M230 78 L350 168" />
      <!-- worker-to-worker NNG mesh -->
      <path class="mesh-line" d="M110 200 L230 200" opacity="0.5" />
      <path class="mesh-line" d="M230 200 L350 200" opacity="0.5" />
    </g>

    <!-- control plane -->
    <g>
      <rect x="150" y="44" width="160" height="40" rx="10" fill="#131a24" stroke="url(#cd-g)" stroke-width="1.6" filter="url(#cd-glow)" />
      <text x="230" y="63" text-anchor="middle" fill="#e6edf3" font-family="ui-monospace, monospace" font-size="12" font-weight="700">Control plane</text>
      <text x="230" y="76" text-anchor="middle" fill="#9aa7b6" font-family="ui-monospace, monospace" font-size="8.5">load-aware scheduler</text>
    </g>

    <!-- worker nodes -->
    {[110, 230, 350].map((cx, i) => (
      <g>
        <rect x={cx - 52} y="168" width="104" height="72" rx="10" fill="#0f141c" stroke="#1e2836" stroke-width="1.4" />
        <text x={cx} y="185" text-anchor="middle" fill="#9aa7b6" font-family="ui-monospace, monospace" font-size="8.5">worker-{i + 1}</text>
        {/* nspawn browser containers */}
        <g class="node-pulse" style={`animation-delay:${i * 0.5}s`}>
          <rect x={cx - 44} y="192" width="26" height="18" rx="4" fill="#131a24" stroke="url(#cd-g)" stroke-width="1.1" />
          <rect x={cx - 13} y="192" width="26" height="18" rx="4" fill="#131a24" stroke="url(#cd-g)" stroke-width="1.1" />
          <rect x={cx + 18} y="192" width="26" height="18" rx="4" fill="#131a24" stroke="#38bdf8" stroke-width="1.1" opacity="0.55" />
        </g>
        <text x={cx} y="228" text-anchor="middle" fill="#6b7889" font-family="ui-monospace, monospace" font-size="7">nspawn browsers</text>
      </g>
    ))}

    <!-- dormancy store -->
    <g>
      <rect x="180" y="262" width="100" height="26" rx="8" fill="#0f141c" stroke="#1e2836" stroke-width="1.2" stroke-dasharray="3 3" />
      <text x="230" y="279" text-anchor="middle" fill="#6b7889" font-family="ui-monospace, monospace" font-size="8">snapshot dormancy</text>
    </g>
    <path class="mesh-line" d="M230 240 L230 262" stroke="#38bdf8" stroke-width="1.2" fill="none" opacity="0.4" />
  </svg>
  <p class="cap">{caption}</p>
</div>
