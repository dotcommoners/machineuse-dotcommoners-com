---
import { NAV } from '../data/site.js';
---
<header class="site-header">
  <div class="wrap">
    <a class="brand" href="/" aria-label="Machineuse home">
      <span class="dot" aria-hidden="true"></span>
      Machineuse
    </a>
    <nav class="nav" id="site-nav" aria-label="Primary">
      {NAV.map((item) => (
        <a href={item.href} class={item.label === 'Docs' || item.label === 'GitHub' ? 'hide-sm' : ''}>{item.label}</a>
      ))}
    </nav>
    <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="site-nav">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>
</header>
<script>
  const btn = document.getElementById('nav-toggle');
  const nav = document.getElementById('site-nav');
  btn?.addEventListener('click', () => {
    const open = nav.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
